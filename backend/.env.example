DATABASE_URL=postgresql://chatbot:chatbot@localhost:5432/chatbot
JWT_SECRET=change-this-to-a-random-32-char-string-in-production
JWT_EXPIRE_MINUTES=10080

APP_NAME=OU Chatbot API
APP_ENV=development
API_PREFIX=/api
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
LLM_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.1-8b-instant
CHROMA_PERSIST_DIR=./chroma_db
TOP_K=3
MIN_CONFIDENCE_SCORE=0.6
CONFIDENCE_SCORE_SCALE=2.5
RERANK_SEMANTIC_WEIGHT=0.5
RERANK_KEYWORD_WEIGHT=0.2
RERANK_SOURCE_URL_WEIGHT=0.2
RERANK_SHORT_CHUNK_PENALTY=0.05
RERANK_LONG_CHUNK_PENALTY=0.03
FEEDBACK_STORE_PATH=./chat_feedback.jsonl
CHAT_STORE_PATH=./chat_history.jsonl
ALLOWED_INGEST_DOMAINS=oakland.edu,support.oakland.edu
INGEST_MAX_DOCX_FILES=1000
INGEST_MAX_CRAWL_PAGES=1000
TDX_BASE_URL=
TDX_API_TOKEN=
TDX_ARTICLES_PATH=/api/v1/knowledgebase/search
TDX_TICKET_CREATE_PATH=/api/v1/tickets
TDX_TIMEOUT_SECONDS=20
TDX_MAX_RETRIES=2
PURECHAT_WIDGET_ID=
RATE_LIMIT_PER_MINUTE=60
AUTH_ENABLED=false
ENTRA_ISSUER=
ENTRA_AUDIENCE=
ENTRA_JWKS_URL=
ENTRA_JWT_ALGORITHMS=RS256,HS256
ENTRA_TEST_HS256_SECRET=
